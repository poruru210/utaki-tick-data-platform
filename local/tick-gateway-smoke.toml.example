listen_address = "127.0.0.1:17003"
gateway_instance_id = "gateway-r2-smoke-01"
max_frame_bytes = 1048576
max_records = 4096
wal_root = "./smoke/wal"
raw_outbox_root = "./smoke/raw-outbox"
journal_path = "./smoke/journal/gateway.sqlite"
initial_from_msc = 0
initial_batch_count = 128
maximum_batch_count = 4096
dense_boundary_hard_cap = 4096
session_lease_timeout_ms = 30000
heartbeat_idle_timeout_ms = 60000
producer_instance_id = "mt5-r2-smoke-01"
producer_build_id = "tick-capture-mt5-v1"
dataset_id = "dataset-r2-smoke"
provider_id = "broker-provider"
stable_feed_id = "broker-feed-01"
broker_server_fingerprint = "broker-server-smoke"
exact_source_symbol = "EURUSD"
gateway_build_identity = "tick-gateway-r2-smoke"
day_definition_id = "utc-day-v1"
settle_policy = "manual-v1"
publisher_id = "publisher-r2-smoke"
publisher_epoch = 1

[credentials]
provider = "file"
path = "./smoke/secrets/tick-gateway-r2.json"
protection = "native-acl"

[r2]
endpoint = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
bucket = "replace-with-isolated-r2-bucket"
region = "auto"
immutable_root = "g6-smoke/replace-with-run-id"

[publication]
catalog_path = "./smoke/journal/catalog.sqlite"
remote_journal_path = "./smoke/journal/publication.sqlite"
manifest_root = "./smoke/manifests"
receipt_root = "./smoke/receipts"
seal_max_bytes = 4096
seal_interval_ms = 2000
scan_interval_ms = 500
retry_min_ms = 1000
retry_max_ms = 10000
max_pending_segments = 64
max_pending_bytes = 67108864
