# Copy this file to env.local for an isolated R2 smoke run.
# Keep env.local untracked and never use production bucket/root values here.

TICK_R2_BUCKET=replace-with-isolated-r2-bucket
TICK_R2_IMMUTABLE_ROOT=smoke
TICK_R2_ENDPOINT=https://replace-with-account-id.r2.cloudflarestorage.com
TICK_R2_ACCESS_KEY_ID=replace-with-bucket-scoped-access-key
TICK_R2_SECRET_ACCESS_KEY=replace-with-bucket-scoped-secret-key
TICK_GATEWAY_INSTANCE_ID=replace-with-gateway-instance-id
